# Copy this file to `.env` and adjust as needed.
# The server runs fine with the defaults below, so a .env is optional for local dev.

# Port the API listens on
PORT=4000

# Secret used to sign JWTs. CHANGE THIS in any real deployment.
JWT_SECRET=dev-secret-change-me

# How long an issued token stays valid
JWT_EXPIRES_IN=7d

# Comma-separated list of origins allowed by CORS (the frontend dev server).
CLIENT_ORIGIN=http://localhost:5173
